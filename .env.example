# Google Apps Script (inventory read/write) — WAJIB diisi
NEXT_PUBLIC_GOOGLE_SCRIPT_URL=

# API Secret Key untuk proteksi endpoint write (/api/gsheet)
API_SECRET_KEY=

# Backend GraphQL API (opsional, untuk production)
GRAPHQL_URL=http://localhost:4000/graphql

# Better Auth Configuration (opsional, untuk production)
NEXT_PUBLIC_AUTH_URL=http://localhost:4000/api/auth

# Ollama AI (opsional, untuk AI Assistant)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:14b

# Note: If you use npm start (production mode), please remember that
# npm run build must be run after configuring environment variables for
# changes to take effect. This is not needed when using npm run dev.